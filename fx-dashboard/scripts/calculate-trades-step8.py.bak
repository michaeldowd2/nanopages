#!/usr/bin/env python3
"""
Trade Calculator (Step 8)

Generates trade recommendations based on strategy configurations and aggregated signals from Step 7.
Outputs detailed trade records showing costs due to spreads WITHOUT executing on portfolios.

Input: Step 7 aggregated signals (step7_aggregated_signals.csv)
Output: CSV with one row per trade showing:
- strategy_id, date, from_currency, to_currency
- from_amount_euro, from_amount_base (source currency)
- exchange_rate_with_spread, exchange_rate_mid
- to_amount_euro, to_amount_opposite (target currency)
- cost_euro (spread cost)

This allows us to:
1. See trade costs in isolation before portfolio execution
2. Validate trade logic on Day 1 when everything is in EUR
3. Separate spread costs from exchange rate fluctuations
"""

import json
import os
import sys
import glob
import argparse
from datetime import datetime

sys.path.append('/workspace/group/fx-portfolio/scripts')
from pipeline_logger import PipelineLogger
from config_loader import get_strategies

CURRENCIES = ["EUR", "USD", "GBP", "JPY", "CHF", "AUD", "CAD", "NOK", "SEK", "CNY", "MXN"]

REVOLUT_SPREADS = {
    'default': 0.0074  # 0.74% average (0.37% each side)
}

def load_latest_prices(date_str=None):
    """
    Load exchange rates from Step 1 for a specific date.

    Parameters:
    - date_str: YYYY-MM-DD date to load prices for. If None, loads most recent.

    Returns: (eur_rates, all_pairs)
    """
    if date_str:
        # Load specific date
        price_file = f'/workspace/group/fx-portfolio/data/prices/fx-rates-{date_str}.json'
        if os.path.exists(price_file):
            with open(price_file, 'r') as f:
                data = json.load(f)
                eur_rates = data.get('eur_base_rates', data.get('rates', {}))
                all_pairs = data.get('all_pairs', {})
                return eur_rates, all_pairs
        else:
            # Date not found, fall back to latest
            print(f"Warning: No price data for {date_str}, using latest available")

    # Load most recent if no date specified or date not found
    price_files = sorted(glob.glob('/workspace/group/fx-portfolio/data/prices/fx-rates-*.json'))

    if not price_files:
        return None, None

    with open(price_files[-1], 'r') as f:
        data = json.load(f)
        eur_rates = data.get('eur_base_rates', data.get('rates', {}))
        all_pairs = data.get('all_pairs', {})
        return eur_rates, all_pairs

def load_aggregated_signals(date_str=None, generator_ids=None, estimator_ids=None):
    """
    Load aggregated signals from Step 7, filtered by generator and estimator IDs.

    Returns: (aggregated_signals_by_currency, actual_date_str)

    aggregated_signals_by_currency format:
    {
        'USD': [
            {'generator_id': 'keyword-sentiment-v1.1-standard',
             'estimator_id': 'llm-horizon-v1-default',
             'aggregate_direction': 'bullish',
             'aggregate_confidence': 0.1286},
            ...
        ],
        ...
    }
    """
    import csv

    step7_csv = '/workspace/group/fx-portfolio/data/exports/step7_aggregated_signals.csv'

    if not os.path.exists(step7_csv):
        # No Step 7 data available
        aggregated_by_currency = {curr: [] for curr in CURRENCIES}
        inferred_date = date_str if date_str else datetime.now().strftime('%Y-%m-%d')
        return aggregated_by_currency, inferred_date

    aggregated_by_currency = {curr: [] for curr in CURRENCIES}
    dates_with_data = set()

    with open(step7_csv, 'r') as f:
        reader = csv.DictReader(f)
        for row in reader:
            row_date = row['date']

            # Filter by date if specified
            if date_str and row_date != date_str:
                continue

            # Filter by generator
            if generator_ids and row['generator_id'] not in generator_ids:
                continue

            # Filter by estimator
            if estimator_ids and row['estimator_id'] not in estimator_ids:
                continue

            currency = row['currency']
            if currency in CURRENCIES:
                dates_with_data.add(row_date)

                # Store aggregated signal data
                agg_signal = {
                    'generator_id': row['generator_id'],
                    'estimator_id': row['estimator_id'],
                    'aggregate_direction': row['aggregate_direction'],
                    'aggregate_confidence': float(row['aggregate_confidence']),
                    'signal_count': int(row['signal_count']),
                    'avg_confidence': float(row['avg_confidence'])
                }
                aggregated_by_currency[currency].append(agg_signal)

    # Determine actual date used
    if date_str:
        actual_date = date_str
    elif dates_with_data:
        actual_date = max(dates_with_data)
    else:
        actual_date = datetime.now().strftime('%Y-%m-%d')

    return aggregated_by_currency, actual_date

def combine_aggregated_signals(aggregated_signals, generator_weights=None):
    """
    Combine multiple aggregated signals (from different generator/estimator combinations)
    for a single currency using weighted averaging.

    Each aggregated signal is already a weighted average from Step 7.
    Here we're combining across different generator/estimator combinations.

    Returns: (direction, confidence, total_signal_count)
    """
    if not aggregated_signals:
        return 'neutral', 0.0, 0

    weighted_scores = []
    total_weight = 0.0
    total_signal_count = 0

    for agg_sig in aggregated_signals:
        # aggregate_confidence is now SIGNED (positive=bullish, negative=bearish)
        signed_confidence = agg_sig.get('aggregate_confidence', 0.0)
        signal_count = agg_sig.get('signal_count', 0)
        generator_id = agg_sig.get('generator_id', '')

        # Apply generator weight if specified
        gen_weight = 1.0
        if generator_weights and generator_id in generator_weights:
            gen_weight = generator_weights[generator_id]

        # Use signed confidence directly (no need to convert from direction)
        weighted_scores.append(signed_confidence * gen_weight)
        total_weight += gen_weight
        total_signal_count += signal_count

    # Calculate final weighted average
    avg_score = sum(weighted_scores) / total_weight if total_weight > 0 else 0

    # Determine final direction (return SIGNED confidence)
    if avg_score > 0.1:
        return 'bullish', avg_score, total_signal_count  # Positive
    elif avg_score < -0.1:
        return 'bearish', avg_score, total_signal_count  # Negative
    else:
        return 'neutral', avg_score, total_signal_count  # Near-zero

def calculate_portfolio_value(portfolio, eur_rates):
    """Calculate total portfolio value in EUR"""
    total_eur = 0.0

    for currency, amount in portfolio.items():
        if amount <= 0:
            continue

        if currency == 'EUR':
            total_eur += amount
        else:
            rate = eur_rates.get(currency)
            if rate:
                total_eur += amount / rate

    return round(total_eur, 2)

def generate_trades_for_strategy(strategy_id, aggregate_signals, confidence_threshold, max_trade_size_pct,
                                  eur_rates, all_pairs, date_str):
    """
    Generate prioritized list of trades for a single strategy.

    Each trade represents a pair: buy strongest bullish currency, sell strongest bearish currency.
    Trades are ordered by combined confidence (descending).

    Returns: List of trade dicts with:
    - buy_currency, sell_currency
    - trade_confidence (average of abs(buy_conf) and abs(sell_conf))
    - above_threshold (True/False based on confidence_threshold)
    - max_trade_size_pct (strategy parameter for execution sizing)
    """
    trades = []

    # Separate bullish and bearish signals (ignore neutral)
    bullish = []
    bearish = []

    for curr, (direction, conf) in aggregate_signals.items():
        if direction == 'bullish' and conf > 0:
            bullish.append((curr, conf))
        elif direction == 'bearish' and conf < 0:
            bearish.append((curr, conf))

    # Sort by strength: bullish descending (highest first), bearish by abs (most negative first)
    bullish = sorted(bullish, key=lambda x: x[1], reverse=True)
    bearish = sorted(bearish, key=lambda x: abs(x[1]), reverse=True)

    # Pair strongest bullish with strongest bearish
    for i in range(min(len(bullish), len(bearish))):
        buy_currency, buy_conf = bullish[i]  # Positive
        sell_currency, sell_conf = bearish[i]  # Negative

        # Trade confidence is the average of the two absolute values
        trade_confidence = (abs(buy_conf) + abs(sell_conf)) / 2.0

        # Check if above threshold
        above_threshold = trade_confidence >= confidence_threshold

        trades.append({
            'strategy_id': strategy_id,
            'date': date_str,
            'buy_currency': buy_currency,
            'sell_currency': sell_currency,
            'buy_confidence': round(buy_conf, 4),
            'sell_confidence': round(sell_conf, 4),
            'trade_confidence': round(trade_confidence, 4),
            'above_threshold': above_threshold,
            'max_trade_size_pct': max_trade_size_pct  # Strategy parameter for execution
        })

    # Sort trades by confidence descending (strongest first)
    trades = sorted(trades, key=lambda x: x['trade_confidence'], reverse=True)

    return trades

def main():
    """Calculate trades for all strategies"""
    parser = argparse.ArgumentParser(description='Calculate trades for strategies (Step 8)')
    parser.add_argument('--date', help='Date filter (YYYY-MM-DD) - uses data from this date')
    args = parser.parse_args()

    logger = PipelineLogger('step8', 'Calculate Trades')
    logger.start()

    # Use specified date or infer from signals
    date_str = args.date if args.date else None

    # Validate upstream data (Step 7: Aggregated Signals)
    step7_csv = '/workspace/group/fx-portfolio/data/exports/step7_aggregated_signals.csv'
    if not os.path.exists(step7_csv):
        logger.error("Step 7 output not found. Run Step 7 (Aggregate Signals) first.")
        logger.fail()
        sys.exit(1)

    print(f"\n{'='*60}")
    print("Validating Upstream Data (Step 7)")
    print(f"{'='*60}")
    print(f"  ✓ Found Step 7 aggregated signals: {step7_csv}")

    # If date specified, verify Step 7 has data for that date
    if date_str:
        import csv
        dates_in_step7 = set()
        with open(step7_csv, 'r') as f:
            reader = csv.DictReader(f)
            for row in reader:
                dates_in_step7.add(row['date'])

        if date_str not in dates_in_step7:
            logger.error(f"Step 7 has no data for {date_str}. Available dates: {sorted(dates_in_step7)}")
            logger.fail()
            sys.exit(1)

        print(f"  ✓ Step 7 has data for {date_str}")

    # Load strategies
    strategies = get_strategies()
    strategy_list = list(strategies.items())

    logger.add_count('strategy_combinations', len(strategy_list))

    all_trades = []
    eur_rates = None
    all_pairs = None

    try:
        for i, (strategy_id, strategy_config) in enumerate(strategy_list, 1):
            params = strategy_config.get('params', {})

            conf_threshold = params.get('confidence_threshold', 0.5)
            max_trade_size_pct = params.get('trade_size_pct', 0.1)
            estimator_ids = params.get('estimator_ids', [])
            generator_ids = params.get('generator_ids', [])
            generator_weights = params.get('generator_weights', {})

            print(f"\n[{i}/{len(strategy_list)}] Calculating trades: {strategy_id}")
            print(f"  conf_threshold={conf_threshold}")
            print(f"  max_trade_size_pct={max_trade_size_pct}")

            # Load aggregated signals from Step 7
            aggregated_by_currency, actual_date = load_aggregated_signals(date_str, generator_ids, estimator_ids)

            # Use actual date for all trades (first strategy sets it, all should be same)
            if i == 1:
                date_str = actual_date
                print(f"  Using data date: {date_str}")

                # Load price data for the determined date
                eur_rates, all_pairs = load_latest_prices(date_str)
                if not eur_rates or not all_pairs:
                    logger.error(f"No price data available for {date_str}")
                    logger.fail()
                    return

            # Combine aggregated signals (if multiple generator/estimator combos for same currency)
            aggregate_signals = {}
            for currency, agg_signals in aggregated_by_currency.items():
                direction, confidence, volume = combine_aggregated_signals(
                    agg_signals,
                    generator_weights=generator_weights
                )
                aggregate_signals[currency] = (direction, confidence)

            # Generate trades (no longer needs portfolio value - that's for execution)
            trades = generate_trades_for_strategy(
                strategy_id,
                aggregate_signals,
                conf_threshold,
                max_trade_size_pct,
                eur_rates,
                all_pairs,
                date_str
            )

            all_trades.extend(trades)
            above_threshold_count = sum(1 for t in trades if t['above_threshold'])
            print(f"  Generated trades: {len(trades)} ({above_threshold_count} above threshold)")

        # Save to CSV
        output_dir = '/workspace/group/fx-portfolio/data/exports'
        os.makedirs(output_dir, exist_ok=True)

        import csv
        csv_file = f'{output_dir}/step8_trades.csv'

        if all_trades:
            fieldnames = [
                'date', 'strategy_id', 'buy_currency', 'sell_currency',
                'buy_confidence', 'sell_confidence', 'trade_confidence',
                'above_threshold', 'max_trade_size_pct'
            ]

            # Safely handle appending vs overwriting based on dates
            file_exists = os.path.exists(csv_file)

            if not date_str:
                # SAFETY: Should never happen - date_str should always be set by now
                logger.error("CRITICAL: date_str is None when writing CSV!")
                raise ValueError("date_str must be set before writing trades CSV")

            if file_exists:
                # Read existing data
                with open(csv_file, 'r') as f:
                    reader = csv.DictReader(f)
                    existing_rows = list(reader)

                # Filter out any existing rows for this date (we're replacing them)
                other_date_rows = [row for row in existing_rows if row.get('date') != date_str]

                # Write everything: other dates + new trades for current date
                with open(csv_file, 'w', newline='') as f:
                    writer = csv.DictWriter(f, fieldnames=fieldnames)
                    writer.writeheader()
                    # Write other dates first
                    writer.writerows(other_date_rows)
                    # Write current date
                    writer.writerows(all_trades)
            else:
                # New file - just write the trades
                with open(csv_file, 'w', newline='') as f:
                    writer = csv.DictWriter(f, fieldnames=fieldnames)
                    writer.writeheader()
                    writer.writerows(all_trades)

            above_threshold_trades = [t for t in all_trades if t['above_threshold']]
            logger.add_count('total_trades', len(all_trades))
            logger.add_count('above_threshold_trades', len(above_threshold_trades))
            logger.add_info('output_csv', csv_file)

            print(f"\n{'='*60}")
            print(f"✓ Calculated {len(all_trades)} trades across {len(strategy_list)} strategies")
            print(f"  ({len(above_threshold_trades)} trades above confidence threshold)")
            print(f"CSV: {csv_file}")
            print(f"{'='*60}")
        else:
            # Write empty CSV with headers
            with open(csv_file, 'w', newline='') as f:
                writer = csv.DictWriter(f, fieldnames=[
                    'date', 'strategy_id', 'buy_currency', 'sell_currency',
                    'buy_confidence', 'sell_confidence', 'trade_confidence',
                    'above_threshold', 'max_trade_size_pct'
                ])
                writer.writeheader()

            print(f"\n{'='*60}")
            print(f"⚠️  No trades generated (no qualifying bull/bear pairs)")
            print(f"CSV: {csv_file}")
            print(f"{'='*60}")

        logger.success()

    except Exception as e:
        logger.error(f"Failed to calculate trades: {e}")
        logger.fail()
        raise
    finally:
        logger.finish()

if __name__ == '__main__':
    main()
