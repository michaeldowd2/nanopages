{
  "version": "2.0",
  "description": "FX Portfolio Trading Pipeline - Step Dependencies and Configuration",
  "steps": {
    "1": {
      "id": "1",
      "name": "Exchange Rates",
      "script": "scripts/pipeline/fetch-exchange-rates.py",
      "description": "Fetch current exchange rates from API",
      "depends_on": [],
      "inputs": [],
      "outputs": {
        "primary": "data/prices/fx-rates-{date}.json",
        "patterns": ["data/prices/fx-rates-*.json"]
      },
      "supports_date_filter": true,
      "is_safe_to_clear": true
    },
    "2": {
      "id": "2",
      "name": "Currency Indices",
      "script": "scripts/pipeline/calculate-currency-indices.py",
      "description": "Calculate synthetic currency strength indices",
      "depends_on": ["1"],
      "inputs": [
        "data/prices/fx-rates-{date}.json"
      ],
      "outputs": {
        "primary": "data/indices/{currency}_index.json",
        "patterns": ["data/indices/*.json"]
      },
      "supports_date_filter": true,
      "is_safe_to_clear": true
    },
    "3": {
      "id": "3",
      "name": "News Aggregation",
      "script": "scripts/pipeline/fetch-news.py",
      "description": "Fetch and store news articles from various sources",
      "depends_on": [],
      "inputs": [],
      "outputs": {
        "primary": "data/news/{currency}/{date}_{source}.json",
        "patterns": ["data/news/*/*.json", "data/news/url_index.json"]
      },
      "supports_date_filter": true,
      "is_safe_to_clear": true,
      "warning": "Clearing news articles will require re-fetching from external APIs"
    },
    "4": {
      "id": "4",
      "name": "Time Horizon Analysis",
      "script": "scripts/pipeline/analyze-time-horizons.py",
      "description": "Extract time horizons from articles using LLM",
      "depends_on": ["3"],
      "inputs": [
        "data/news/{currency}/{date}_{source}.json"
      ],
      "outputs": {
        "primary": "data/article-analysis/{date}.json",
        "patterns": ["data/article-analysis/*.json"]
      },
      "supports_date_filter": true,
      "is_safe_to_clear": true,
      "warning": "Uses LLM API - clearing will incur re-analysis costs"
    },
    "4.1": {
      "id": "4.1",
      "name": "Currency Events",
      "script": null,
      "description": "Taxonomy of currency-affecting events with keywords and signal characteristics",
      "depends_on": [],
      "inputs": [],
      "outputs": {
        "primary": "data/events/currency_events.json",
        "patterns": ["data/events/currency_events.json"]
      },
      "supports_date_filter": false,
      "is_safe_to_clear": false,
      "note": "Static reference data - manually curated event taxonomy"
    },
    "5": {
      "id": "5",
      "name": "Sentiment Signals",
      "script": "scripts/pipeline/generate-sentiment-signals.py",
      "description": "Generate sentiment signals using keyword and LLM generators",
      "depends_on": ["3"],
      "inputs": [
        "data/news/{currency}/{date}_{source}.json"
      ],
      "outputs": {
        "primary": "data/signals/{currency}/{date}.json",
        "patterns": ["data/signals/*/*.json"]
      },
      "supports_date_filter": true,
      "is_safe_to_clear": true,
      "warning": "Uses LLM API - clearing will incur re-generation costs"
    },
    "6": {
      "id": "6",
      "name": "Signal Realization",
      "script": "scripts/pipeline/check-signal-realization.py",
      "description": "Check if signals have been realized (predicted events occurred)",
      "depends_on": ["5", "4", "2"],
      "inputs": [
        "data/signals/{currency}/{date}.json",
        "data/article-analysis/{date}.json",
        "data/indices/{currency}_index.json"
      ],
      "outputs": {
        "primary": "data/signal-realization/{date}.json",
        "patterns": ["data/signal-realization/*.json"]
      },
      "supports_date_filter": true,
      "is_safe_to_clear": true,
      "note": "Joins signals with horizons and index data"
    },
    "7": {
      "id": "7",
      "name": "Signal Aggregation",
      "script": "scripts/pipeline/aggregate-signals.py",
      "description": "Aggregate unrealized signals by generator/estimator/currency",
      "depends_on": ["6"],
      "inputs": [
        "data/signal-realization/*.json"
      ],
      "outputs": {
        "primary": "data/aggregated-signals/aggregated_signals.csv",
        "patterns": ["data/aggregated-signals/aggregated_signals.csv"]
      },
      "supports_date_filter": true,
      "is_safe_to_clear": true
    },
    "8": {
      "id": "8",
      "name": "Trade Calculation",
      "script": "scripts/pipeline/calculate-trades.py",
      "description": "Calculate proposed trades with spread cost analysis",
      "depends_on": ["7"],
      "inputs": [
        "data/aggregated-signals/aggregated_signals.csv"
      ],
      "outputs": {
        "primary": "data/trades/trades.csv",
        "patterns": ["data/trades/trades.csv"]
      },
      "supports_date_filter": true,
      "is_safe_to_clear": true
    },
    "9": {
      "id": "9",
      "name": "Portfolio Execution",
      "script": "scripts/pipeline/execute-strategies.py",
      "description": "Execute trades on portfolios and track values",
      "depends_on": ["1", "8"],
      "inputs": [
        "data/prices/fx-rates-{date}.json",
        "data/trades/trades.csv",
        "data/portfolios/strategies.csv"
      ],
      "outputs": {
        "primary": "data/portfolios/strategies.csv",
        "patterns": ["data/portfolios/strategies.csv"]
      },
      "supports_date_filter": true,
      "is_safe_to_clear": false,
      "warning": "Portfolio state is cumulative - clearing resets all portfolio history!"
    },
    "10": {
      "id": "10",
      "name": "Dashboard Deployment",
      "script": "scripts/deployment/export-pipeline-data.py",
      "description": "Export pipeline data to site_data for dashboard",
      "depends_on": ["1", "2", "3", "4", "5", "6", "7", "8", "9"],
      "inputs": [
        "data/prices/*.json",
        "data/indices/*.json",
        "data/news/*/*.json",
        "data/article-analysis/*.json",
        "data/signals/*/*.json",
        "data/signal-realization/*.json",
        "data/aggregated-signals/*.csv",
        "data/trades/*.csv",
        "data/portfolios/*.csv"
      ],
      "outputs": {
        "primary": "site_data/",
        "patterns": [
          "site_data/step1_*.csv",
          "site_data/step2_*.csv",
          "site_data/step3_*.csv",
          "site_data/step4_*.csv",
          "site_data/step5_*.csv",
          "site_data/step6_*.csv",
          "site_data/step7_*.csv",
          "site_data/step8_*.csv",
          "site_data/step9_*.csv"
        ]
      },
      "supports_date_filter": false,
      "is_safe_to_clear": false,
      "note": "Exports all pipeline data to dashboard format"
    }
  },
  "notes": {
    "dependency_rules": [
      "Steps must be run in dependency order",
      "Clearing a step requires clearing all downstream dependencies",
      "Portfolio state (Step 9) is cumulative across dates",
      "LLM-based steps (4, 5) incur API costs when regenerated"
    ],
    "date_filtering": [
      "Most steps support date-specific operations",
      "Portfolio execution (Step 9) maintains state across dates",
      "Deployment (Step 10) always includes all available dates"
    ],
    "safety_guidelines": [
      "Always clear downstream before clearing upstream (prevents orphaned data)",
      "Use --dry-run to preview what will be cleared",
      "Back up portfolio state before clearing Step 9",
      "News articles (Step 3) may not be re-fetchable for old dates"
    ]
  }
}
