{
  "version": "4.0",
  "description": "FX Portfolio Trading Pipeline - Refactored config with embedded schemas",
  "steps": {
    "1": {
      "id": "1",
      "name": "Exchange Rates",
      "script": "scripts/pipeline/fetch-exchange-rates.py",
      "description": "Fetch current exchange rates from API",
      "depends_on": [],
      "inputs": [],
      "output_path": "data/prices/{date}.csv",
      "output_pattern": "data/prices/*.csv",
      "output_schema": {
        "description": "Exchange rates for all currency pairs",
        "columns": [
          {
            "name": "date",
            "type": "string",
            "description": "Trading date YYYY-MM-DD"
          },
          {
            "name": "base_currency",
            "type": "string",
            "description": "Base currency (always EUR)"
          },
          {
            "name": "quote_currency",
            "type": "string",
            "description": "Quote currency code"
          },
          {
            "name": "rate",
            "type": "float",
            "description": "Exchange rate (quote/base)"
          }
        ]
      },
      "supports_date_filter": true,
      "is_safe_to_clear": false,
      "warning": "Historical exchange rates may not be re-fetchable for past dates",
      "number_of_export_dates": 30
    },
    "2": {
      "id": "2",
      "name": "Currency Indices",
      "script": "scripts/pipeline/calculate-currency-indices.py",
      "description": "Calculate synthetic currency strength indices",
      "depends_on": [
        "1"
      ],
      "inputs": [
        "data/prices/{date}.csv"
      ],
      "output_path": "data/indices/{date}.csv",
      "output_pattern": "data/indices/*.csv",
      "output_schema": {
        "description": "Currency strength indices calculated using percent-change method (base 100)",
        "columns": [
          {
            "name": "date",
            "type": "string",
            "description": "Trading date YYYY-MM-DD"
          },
          {
            "name": "currency",
            "type": "string",
            "description": "Currency code"
          },
          {
            "name": "index",
            "type": "float",
            "description": "Currency strength index (base date = 100, calculated via percent changes from base)"
          },
          {
            "name": "30d_max_diff",
            "type": "float",
            "description": "Difference between max and min index values over the past 30 days"
          }
        ]
      },
      "supports_date_filter": true,
      "is_safe_to_clear": true,
      "number_of_export_dates": 30
    },
    "3": {
      "id": "3",
      "name": "News Aggregation",
      "script": "scripts/pipeline/fetch-news.py",
      "description": "Fetch and store news articles from various sources",
      "depends_on": [],
      "inputs": [],
      "output_path": "data/news/{date}.csv",
      "output_pattern": "data/news/*.csv",
      "output_schema": {
        "description": "News articles aggregated from multiple sources",
        "columns": [
          {
            "name": "date",
            "type": "string",
            "description": "Article fetch date YYYY-MM-DD"
          },
          {
            "name": "article_id",
            "type": "string",
            "description": "Short hash ID derived from URL (12-char hex)"
          },
          {
            "name": "source",
            "type": "string",
            "description": "News source name"
          },
          {
            "name": "url",
            "type": "string",
            "description": "Article URL (unique identifier)"
          },
          {
            "name": "currency",
            "type": "string",
            "description": "Currency the article relates to"
          },
          {
            "name": "title",
            "type": "string",
            "description": "Article title"
          },
          {
            "name": "snippet",
            "type": "string",
            "description": "Article snippet/summary"
          }
        ]
      },
      "supports_date_filter": true,
      "is_safe_to_clear": false,
      "warning": "News articles for past dates cannot be re-fetched - APIs only provide current/recent news",
      "number_of_export_dates": 30
    },
    "4": {
      "id": "4",
      "name": "Time Horizon Analysis",
      "script": "scripts/pipeline/analyze-time-horizons.py",
      "description": "Extract time horizons from articles using LLM",
      "depends_on": [
        "3"
      ],
      "inputs": [
        "data/news/{date}.csv"
      ],
      "output_path": "data/article-analysis/{date}.csv",
      "output_pattern": "data/article-analysis/*.csv",
      "output_schema": {
        "description": "Time horizon analysis for articles using LLM",
        "columns": [
          {
            "name": "date",
            "type": "string",
            "description": "Analysis date YYYY-MM-DD"
          },
          {
            "name": "article_id",
            "type": "string",
            "description": "Short hash ID derived from URL (12-char hex)"
          },
          {
            "name": "currency",
            "type": "string",
            "description": "Currency the article relates to"
          },
          {
            "name": "estimator_id",
            "type": "string",
            "description": "Estimator identifier"
          },
          {
            "name": "time_horizon",
            "type": "string",
            "description": "Time horizon label (1day, 1week, 2week, 1month)"
          },
          {
            "name": "horizon_days",
            "type": "int",
            "description": "Horizon in days"
          },
          {
            "name": "valid_to_date",
            "type": "string",
            "description": "Date when horizon expires YYYY-MM-DD"
          },
          {
            "name": "reasoning",
            "type": "string",
            "description": "LLM reasoning for horizon assignment"
          }
        ]
      },
      "supports_date_filter": true,
      "is_safe_to_clear": true,
      "warning": "Uses LLM API - clearing will incur re-analysis costs",
      "number_of_export_dates": 30
    },
    "4.1": {
      "id": "4.1",
      "name": "Currency Events",
      "script": null,
      "description": "Taxonomy of currency-affecting events with keywords and signal characteristics",
      "depends_on": [],
      "inputs": [],
      "output_path": "data/events/currency_events.json",
      "output_pattern": "data/events/currency_events.json",
      "supports_date_filter": false,
      "is_safe_to_clear": false,
      "note": "Static reference data - manually curated event taxonomy (JSON format, not CSV)",
      "number_of_export_dates": 30
    },
    "5": {
      "id": "5",
      "name": "Sentiment Signals",
      "script": "scripts/pipeline/generate-sentiment-signals.py",
      "description": "Generate sentiment signals using keyword and LLM generators",
      "depends_on": [
        "3",
        "4"
      ],
      "inputs": [
        "data/news/{date}.csv",
        "data/article-analysis/{date}.csv"
      ],
      "output_path": "data/signals/{date}.csv",
      "output_pattern": "data/signals/*.csv",
      "output_schema": {
        "description": "Sentiment signals generated from news articles",
        "columns": [
          {
            "name": "date",
            "type": "string",
            "description": "Signal generation date YYYY-MM-DD"
          },
          {
            "name": "article_id",
            "type": "string",
            "description": "Short hash ID derived from URL (12-char hex)"
          },
          {
            "name": "currency",
            "type": "string",
            "description": "Currency the signal relates to"
          },
          {
            "name": "pair_context",
            "type": "string",
            "nullable": true,
            "description": "Specific currency pair context if applicable"
          },
          {
            "name": "estimator_id",
            "type": "string",
            "description": "Time horizon estimator ID"
          },
          {
            "name": "valid_to_date",
            "type": "string",
            "description": "Date when horizon expires YYYY-MM-DD"
          },
          {
            "name": "generator_id",
            "type": "string",
            "description": "Signal generator identifier"
          },
          {
            "name": "event_id",
            "type": "string",
            "description": "Currency event identifier (references step 4.1 taxonomy)"
          },
          {
            "name": "predicted_direction",
            "type": "string",
            "description": "Predicted direction (bullish/bearish/neutral)"
          },
          {
            "name": "predicted_magnitude",
            "type": "string",
            "nullable": true,
            "description": "Predicted magnitude (small/medium/large)"
          },
          {
            "name": "base_signal",
            "type": "float",
            "description": "Base signal value from direction and magnitude: +/-1.0 (large), +/-0.7 (medium), +/-0.4 (small), 0 (neutral)"
          },
          {
            "name": "confidence",
            "type": "float",
            "description": "Signal confidence (0-1)"
          },
          {
            "name": "signal",
            "type": "float",
            "description": "Final signal value (confidence \u00d7 base_signal)"
          },
          {
            "name": "reasoning",
            "type": "string",
            "description": "Signal reasoning/explanation"
          }
        ]
      },
      "supports_date_filter": true,
      "is_safe_to_clear": true,
      "warning": "Uses LLM API - clearing will incur re-generation costs",
      "number_of_export_dates": 30
    },
    "6": {
      "id": "6",
      "name": "Signal Realization",
      "script": "scripts/pipeline/check-signal-realization.py",
      "description": "Check if signals have been realized (predicted events occurred)",
      "depends_on": [
        "2",
        "5"
      ],
      "inputs": [
        "data/indices/{date}.csv",
        "data/signals/{date}.csv"
      ],
      "output_path": "data/signal-realization/{date}.csv",
      "output_pattern": "data/signal-realization/*.csv",
      "output_schema": {
        "description": "Signal realization check against actual currency movements",
        "columns": [
          {
            "name": "date",
            "type": "string",
            "description": "Realization check date YYYY-MM-DD"
          },
          {
            "name": "article_id",
            "type": "string",
            "description": "Short hash ID derived from URL (12-char hex)"
          },
          {
            "name": "currency",
            "type": "string",
            "description": "Currency code"
          },
          {
            "name": "article_download_date",
            "type": "string",
            "description": "Date article was fetched"
          },
          {
            "name": "estimator_id",
            "type": "string",
            "description": "Time horizon estimator ID"
          },
          {
            "name": "generator_id",
            "type": "string",
            "description": "Signal generator ID"
          },
          {
            "name": "event_id",
            "type": "string",
            "description": "Currency event identifier (references step 4.1 taxonomy)"
          },
          {
            "name": "valid_to_date",
            "type": "string",
            "description": "Horizon expiry date"
          },
          {
            "name": "signal",
            "type": "float",
            "description": "Numeric signal value"
          },
          {
            "name": "start_30d_max_diff",
            "type": "float",
            "description": "30-day max-min index range at signal generation date"
          },
          {
            "name": "estimated_diff",
            "type": "float",
            "description": "Estimated index movement (signal \u00d7 start_30d_max_diff)"
          },
          {
            "name": "start_index",
            "type": "float",
            "description": "Currency index at signal generation"
          },
          {
            "name": "min_index",
            "type": "float",
            "description": "Minimum index value reached since signal generation"
          },
          {
            "name": "max_index",
            "type": "float",
            "description": "Maximum index value reached since signal generation"
          },
          {
            "name": "index",
            "type": "float",
            "description": "Currency index at realization check date"
          },
          {
            "name": "actual_diff",
            "type": "float",
            "description": "Actual index change (index - start_index)"
          },
          {
            "name": "greatest_positive_travel",
            "type": "float",
            "description": "Greatest upward movement from start_index (max_index - start_index)"
          },
          {
            "name": "greatest_negative_travel",
            "type": "float",
            "description": "Greatest downward movement from start_index (min_index - start_index, negative value)"
          },
          {
            "name": "realized",
            "type": "boolean",
            "description": "Whether signal was realized at any point (index traveled estimated distance in predicted direction)"
          }
        ]
      },
      "supports_date_filter": true,
      "is_safe_to_clear": true,
      "note": "Joins signals with horizons and index data",
      "number_of_export_dates": 5
    },
    "7": {
      "id": "7",
      "name": "Signal Aggregation",
      "script": "scripts/pipeline/aggregate-signals.py",
      "description": "Aggregate unrealized signals by generator/estimator/currency",
      "depends_on": [
        "6"
      ],
      "inputs": [
        "data/signal-realization/*.csv"
      ],
      "output_path": "data/aggregated-signals/{date}.csv",
      "output_pattern": "data/aggregated-signals/*.csv",
      "output_schema": {
        "description": "Aggregated unrealized signals by generator/estimator/currency with penalty factor",
        "columns": [
          {
            "name": "date",
            "type": "string",
            "description": "Aggregation date YYYY-MM-DD"
          },
          {
            "name": "currency",
            "type": "string",
            "description": "Currency code"
          },
          {
            "name": "generator_id",
            "type": "string",
            "description": "Signal generator identifier"
          },
          {
            "name": "estimator_id",
            "type": "string",
            "description": "Time horizon estimator identifier"
          },
          {
            "name": "index",
            "type": "float",
            "description": "Current currency index value"
          },
          {
            "name": "signal_count",
            "type": "int",
            "description": "Number of signals in aggregate"
          },
          {
            "name": "penalty_factor",
            "type": "float",
            "description": "Penalty applied for low signal count (0-1)"
          },
          {
            "name": "avg_signal",
            "type": "float",
            "description": "Average signal across all signals in group"
          },
          {
            "name": "factored_avg_signal",
            "type": "float",
            "description": "Average signal after applying penalty factor"
          }
        ]
      },
      "supports_date_filter": true,
      "is_safe_to_clear": true,
      "number_of_export_dates": 30
    },
    "8": {
      "id": "8",
      "name": "Trade Calculation",
      "script": "scripts/pipeline/calculate-trades.py",
      "description": "Calculate proposed trades with spread cost analysis",
      "depends_on": [
        "7"
      ],
      "inputs": [
        "data/aggregated-signals/{date}.csv",
        "data/prices/{date}.csv"
      ],
      "output_path": "data/trades/{date}.csv",
      "output_pattern": "data/trades/*.csv",
      "output_schema": {
        "description": "Proposed trades based on aggregated signals",
        "columns": [
          {
            "name": "date",
            "type": "string",
            "description": "Trade calculation date YYYY-MM-DD"
          },
          {
            "name": "trader_id",
            "type": "string",
            "description": "Trader identifier"
          },
          {
            "name": "buy_currency",
            "type": "string",
            "description": "Currency to buy"
          },
          {
            "name": "sell_currency",
            "type": "string",
            "description": "Currency to sell"
          },
          {
            "name": "buy_signal",
            "type": "float",
            "description": "Buy signal strength"
          },
          {
            "name": "sell_signal",
            "type": "float",
            "description": "Sell signal strength"
          },
          {
            "name": "trade_signal",
            "type": "float",
            "description": "Net trade signal (buy_signal - sell_signal)"
          }
        ]
      },
      "supports_date_filter": true,
      "is_safe_to_clear": true,
      "number_of_export_dates": 30
    },
    "9": {
      "id": "9",
      "name": "Execute Trades",
      "script": "scripts/pipeline/execute-trades.py",
      "description": "Execute trades with exact amounts calculated",
      "depends_on": [
        "1",
        "8"
      ],
      "inputs": [
        "data/prices/{date}.csv",
        "data/trades/{date}.csv",
        "data/portfolios/{prev_date}.csv"
      ],
      "output_path": "data/executed-trades/{date}.csv",
      "output_pattern": "data/executed-trades/*.csv",
      "output_schema": {
        "description": "Executed trades with exact amounts calculated",
        "columns": [
          {
            "name": "date",
            "type": "string",
            "description": "Trading date YYYY-MM-DD"
          },
          {
            "name": "strategy_id",
            "type": "string",
            "description": "Strategy identifier"
          },
          {
            "name": "trader_id",
            "type": "string",
            "description": "Trader identifier"
          },
          {
            "name": "sell_currency",
            "type": "string",
            "description": "Currency sold"
          },
          {
            "name": "buy_currency",
            "type": "string",
            "description": "Currency bought"
          },
          {
            "name": "sell_amount",
            "type": "float",
            "description": "Amount of currency sold"
          },
          {
            "name": "buy_amount",
            "type": "float",
            "description": "Amount of currency bought (after spread)"
          },
          {
            "name": "exchange_rate",
            "type": "float",
            "description": "Exchange rate used"
          },
          {
            "name": "spread_pct",
            "type": "float",
            "description": "Spread percentage applied (0.0074 = 0.74%)"
          },
          {
            "name": "trade_size_eur",
            "type": "float",
            "description": "Trade size in EUR equivalent"
          },
          {
            "name": "cost_eur",
            "type": "float",
            "description": "Spread cost in EUR"
          },
          {
            "name": "trade_signal",
            "type": "float",
            "description": "Net trade signal"
          }
        ]
      },
      "supports_date_filter": true,
      "is_safe_to_clear": true,
      "note": "Definitive trade execution with exact amounts - feeds into Process 10",
      "number_of_export_dates": 30
    },
    "10": {
      "id": "10",
      "name": "Account Balances",
      "script": "scripts/pipeline/calculate-account-balances.py",
      "description": "Update account balances from executed trades",
      "depends_on": [
        "1",
        "9"
      ],
      "inputs": [
        "data/prices/{date}.csv",
        "data/executed-trades/{date}.csv",
        "data/portfolios/{prev_date}.csv"
      ],
      "output_path": "data/portfolios/{date}.csv",
      "output_pattern": "data/portfolios/*.csv",
      "output_schema": {
        "description": "Portfolio execution and state tracking",
        "columns": [
          {
            "name": "date",
            "type": "string",
            "description": "Trading date YYYY-MM-DD"
          },
          {
            "name": "strategy_id",
            "type": "string",
            "description": "Portfolio identifier"
          },
          {
            "name": "trader_id",
            "type": "string",
            "description": "Trader identifier"
          },
          {
            "name": "trades_executed",
            "type": "int",
            "description": "Number of trades executed"
          },
          {
            "name": "EUR",
            "type": "float",
            "description": "EUR balance"
          },
          {
            "name": "USD",
            "type": "float",
            "description": "USD balance"
          },
          {
            "name": "GBP",
            "type": "float",
            "description": "GBP balance"
          },
          {
            "name": "JPY",
            "type": "float",
            "description": "JPY balance"
          },
          {
            "name": "CHF",
            "type": "float",
            "description": "CHF balance"
          },
          {
            "name": "AUD",
            "type": "float",
            "description": "AUD balance"
          },
          {
            "name": "CAD",
            "type": "float",
            "description": "CAD balance"
          },
          {
            "name": "NOK",
            "type": "float",
            "description": "NOK balance"
          },
          {
            "name": "SEK",
            "type": "float",
            "description": "SEK balance"
          },
          {
            "name": "CNY",
            "type": "float",
            "description": "CNY balance"
          },
          {
            "name": "MXN",
            "type": "float",
            "description": "MXN balance"
          }
        ]
      },
      "supports_date_filter": true,
      "is_safe_to_clear": false,
      "warning": "Portfolio state is cumulative - clearing resets all portfolio history!",
      "number_of_export_dates": 30
    },
    "11": {
      "id": "11",
      "name": "Portfolio Performance",
      "script": "scripts/pipeline/calculate-portfolio-performance.py",
      "description": "Calculate multi-currency portfolio valuations and currency-neutral performance metrics",
      "depends_on": [
        "1",
        "7",
        "10"
      ],
      "inputs": [
        "data/prices/{date}.csv",
        "data/aggregated-signals/{date}.csv",
        "data/portfolios/{date}.csv",
        "data/valuations/{prev_date}.csv"
      ],
      "output_path": "data/valuations/{date}.csv",
      "output_pattern": "data/valuations/*.csv",
      "output_schema": {
        "description": "Portfolio valuations in all currencies with performance metrics",
        "columns": [
          {
            "name": "date",
            "type": "string",
            "description": "Valuation date YYYY-MM-DD"
          },
          {
            "name": "strategy_id",
            "type": "string",
            "description": "Portfolio identifier"
          },
          {
            "name": "eur_value",
            "type": "float",
            "decimal_places": 2,
            "description": "Portfolio value in EUR"
          },
          {
            "name": "usd_value",
            "type": "float",
            "decimal_places": 2,
            "description": "Portfolio value in USD"
          },
          {
            "name": "gbp_value",
            "type": "float",
            "decimal_places": 2,
            "description": "Portfolio value in GBP"
          },
          {
            "name": "jpy_value",
            "type": "float",
            "decimal_places": 2,
            "description": "Portfolio value in JPY"
          },
          {
            "name": "chf_value",
            "type": "float",
            "decimal_places": 2,
            "description": "Portfolio value in CHF"
          },
          {
            "name": "aud_value",
            "type": "float",
            "decimal_places": 2,
            "description": "Portfolio value in AUD"
          },
          {
            "name": "cad_value",
            "type": "float",
            "decimal_places": 2,
            "description": "Portfolio value in CAD"
          },
          {
            "name": "nok_value",
            "type": "float",
            "decimal_places": 2,
            "description": "Portfolio value in NOK"
          },
          {
            "name": "sek_value",
            "type": "float",
            "decimal_places": 2,
            "description": "Portfolio value in SEK"
          },
          {
            "name": "cny_value",
            "type": "float",
            "decimal_places": 2,
            "description": "Portfolio value in CNY"
          },
          {
            "name": "mxn_value",
            "type": "float",
            "decimal_places": 2,
            "description": "Portfolio value in MXN"
          },
          {
            "name": "eur_pct_change",
            "type": "float",
            "decimal_places": 2,
            "description": "EUR value % change from previous day"
          },
          {
            "name": "usd_pct_change",
            "type": "float",
            "decimal_places": 2,
            "description": "USD value % change from previous day"
          },
          {
            "name": "gbp_pct_change",
            "type": "float",
            "decimal_places": 2,
            "description": "GBP value % change from previous day"
          },
          {
            "name": "jpy_pct_change",
            "type": "float",
            "decimal_places": 2,
            "description": "JPY value % change from previous day"
          },
          {
            "name": "chf_pct_change",
