      "id": "llm-horizon-v1-default",
      "type": "llm-horizon-estimator-v1",
      "params": {
        "model": "claude-3-haiku-20240307",
        "temperature": 0.3,
        "max_tokens": 500
      },
      "description": "LLM-based horizon extraction via nanoclaw (default)"
    }
  },
  "signal_generators": {
    "keyword-sentiment-v1.1-standard": {
      "id": "keyword-sentiment-v1.1-standard",
      "type": "keyword-sentiment-v1.1",
      "params": {
        "keyword_set": "standard",
        "negation_enabled": true,
        "confidence_boost": 1.5,
        "min_keyword_count": 1,
        "magnitude_estimation": true
      },
      "description": "Keyword-based with 47 bullish, 51 bearish keywords (standard sensitivity)"
